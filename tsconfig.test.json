{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["DOM", "ES2022"],
    "rootDir": "src",
    "outDir": ".test-dist",
    "strict": false,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/data/**/*.ts", "src/engine/**/*.ts", "src/types.ts"]
}
